<?xml version="1.0" encoding="utf-8"?>
<!--
  Fully transparent drawable used as the Android 12+ system splash icon.
  Android forces a launch splash with an icon; making the icon invisible means
  the system splash is just the dark background, so the only branded logo the
  user sees is the in-app animated SVG splash (no duplicate / pixelated icon).
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@android:color/transparent" />
    <size android:width="1dp" android:height="1dp" />
</shape>
