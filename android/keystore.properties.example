# Copy this file to  android/keystore.properties  (gitignored) and fill in your
# release keystore details. This enables `npm run release` to build a SIGNED APK.
#
# Create the keystore once (from the project root):
#   keytool -genkey -v -keystore android/jancho-release.jks \
#     -alias jancho -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile is resolved relative to the android/ folder.

storeFile=jancho-release.jks
storePassword=CHANGE_ME
keyAlias=jancho
keyPassword=CHANGE_ME
