# ─────────────────────────────────────────────────────────────────────────────
#  .gitignore — evalutease-suite
#  Generated by full project audit on 2026-05-23
# ─────────────────────────────────────────────────────────────────────────────

# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/

# ─── Environment variables — NEVER commit secrets ────────────────────────────
.env
.env.*
!.env.example
!.env.test.example

# ─── Build outputs ────────────────────────────────────────────────────────────
dist/
dist-ssr/
build/
.output/
.vinxi/
.nitro/

# ─── Framework / tooling caches ───────────────────────────────────────────────
.tanstack/
.vercel/
.netlify/
.wrangler/
.dev.vars

# ─── Supabase local ───────────────────────────────────────────────────────────
supabase/.temp/
supabase/.branches/

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
vite-dev.log
vite-dev.err.log

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo

# ─── Testing — Playwright ─────────────────────────────────────────────────────
e2e/.auth/
playwright-report/
test-results/
blob-report/
.lhci-data/

# ─── Testing — Vitest / Jest coverage ────────────────────────────────────────
coverage/
.nyc_output/

# ─── Cache ────────────────────────────────────────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.turbo

# ─── Temporary / generated analysis files ────────────────────────────────────
# (these were found loose in project root — output of one-off scripts)
eslint-sonar-out.json
sonar-detail.json
parse-sonar.js
parse-sonar2.js
C:UsersmuhamAppDataTempeslint_out.txt
*.tmp
*.temp

# ─── Load test results (keep scripts, not data) ──────────────────────────────
load-tests/result-*.json

# ─── Claude Code local config ─────────────────────────────────────────────────
.claude/

# ─── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini
ehthumbs.db

